{
  "name": "keepwatching-api-server",
  "version": "1.0.0",
  "description": "API server for the KeepWatching application",
  "type": "module",
  "main": "dist/index.mjs",
  "author": "Andy Gifford",
  "private": true,
  "dependencies": {
    "@ajgifford/keepwatching-common-server": "^0.24.0",
    "@ajgifford/keepwatching-types": "^0.15.0",
    "@express-rate-limit/tsconfig": "^1.0.5",
    "axios": "1.18.0",
    "axios-retry": "^4.5.0",
    "body-parser": "^2.3.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cron-parser": "5.5.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "14.0.0",
    "helmet": "^8.2.0",
    "multer": "^2.2.0",
    "mysql2": "3.22.5",
    "node-cache": "^5.1.2",
    "node-cron": "4.3.0",
    "nodemailer": "9.0.1",
    "socket.io": "^4.8.2",
    "streaming-availability": "^4.5.0",
    "uuid": "^14.0.0",
    "winston": "3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.2",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-jest": "^29.15.2",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jest-html-reporter": "^4.4.0",
    "jest-mock-extended": "^4.0.1",
    "mock-socket": "^9.3.1",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.61.1"
  },
  "resolutions": {
    "js-yaml": "^4.2.0",
    "uuid": "^14.0.0",
    "ws": "^8.20.1"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "rebuild": "yarn clean && yarn build",
    "bump-version": "npm version --no-git-tag-version",
    "start": "node dist/index.mjs",
    "dev": "tsx watch src",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage",
    "serve": "yarn build && pm2 start ecosystem.config.cjs --only keepwatching-api-server --env production",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --config ./.prettierrc.js . --write",
    "format:check": "prettier --config ./.prettierrc.js . --check",
    "type-check": "tsc --noEmit",
    "ci": "yarn format:check && yarn lint && yarn type-check && yarn test:coverage && yarn audit --level high"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
